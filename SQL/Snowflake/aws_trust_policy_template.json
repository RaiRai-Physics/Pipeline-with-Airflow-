{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowSnowflakeAssumeRole",
      "Effect": "Allow",
      "Principal": {
        "AWS": "YOUR_SNOWFLAKE_AWS_IAM_USER_ARN"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "sts:ExternalId": "YOUR_SNOWFLAKE_EXTERNAL_ID"
        }
      }
    }
  ]
}
